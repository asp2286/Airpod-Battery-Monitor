<Window x:Class="AirpodBatteryMonitorWindows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Airpod Battery Monitor" Height="350" Width="525">
    <Grid>
        <ListView ItemsSource="{Binding Devices}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Model" DisplayMemberBinding="{Binding Model}" />
                    <GridViewColumn Header="Left" DisplayMemberBinding="{Binding Data.LeftLevel}" />
                    <GridViewColumn Header="Right" DisplayMemberBinding="{Binding Data.RightLevel}" />
                    <GridViewColumn Header="Case" DisplayMemberBinding="{Binding Data.CaseLevel}" />
                    <GridViewColumn Header="Updated" DisplayMemberBinding="{Binding Data.UpdatedTime}" />
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
