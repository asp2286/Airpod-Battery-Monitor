<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="gnome-shell-extensions">
    <schema path="/org/gnome/shell/extensions/Airpod-Battery-Monitor/" id="org.gnome.shell.extensions.Airpod-Battery-Monitor">
        <key name="airpods-list" type="as">
            <default>[]</default>
            <summary>history of paired devices</summary>
        </key>
        <key name="default-selected-path" type="s">
            <default>''</default>
            <summary>default path for panel indicators</summary>
        </key>
        <key name="enable-indicator" type="b">
            <default>false</default>
            <summary>Enable indicator</summary>
        </key>
        <key name="enable-panel-menu" type="b">
            <default>true</default>
            <summary>Enable Panel-Popupmenu</summary>
        </key>
        <key name="enable-message-tray" type="b">
            <default>false</default>
            <summary>Enable Message tray</summary>
        </key>

    </schema>
</schemalist>
